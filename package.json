{
  "name": "snowball-derby",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "seo:generate": "node --import ./tests/register-loader.mjs ./scripts/generate-seo.mjs",
    "build:typecheck": "tsc -b --force --pretty false",
    "build:vite": "vite build --debug",
    "build": "echo \"== SEO ==\" && npm run seo:generate && echo \"== TypeScript ==\" && npm run build:typecheck && echo \"== Vite ==\" && npm run build:vite",
    "test": "node --import ./tests/register-loader.mjs --test tests/*.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
